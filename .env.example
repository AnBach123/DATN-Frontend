# API Base URL
VITE_API_BASE_URL=http://localhost:8080

# WebSocket Configuration
# URL for WebSocket connection to backend overtime alert service
VITE_WEBSOCKET_URL=http://localhost:8080/ws/overtime-alerts
# Security Configuration
# Set to 'true' to enable auto-logout on 401 errors (production mode)
# Set to 'false' to disable auto-logout (development mode)
VITE_ENABLE_AUTO_LOGOUT=false
